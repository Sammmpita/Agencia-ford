# ==============================================================================
# Seguridad (OBLIGATORIO — la app no arranca sin SECRET_KEY)
# ==============================================================================
# Genera una con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-super-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ==============================================================================
# Base de datos (dejar vacío para usar SQLite en desarrollo)
# ==============================================================================
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# ==============================================================================
# Base de datos PostgreSQL (producción / Railway)
# ==============================================================================
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=railway
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_HOST=your-host.railway.app
# DB_PORT=5432

# ==============================================================================
# CORS (orígenes del frontend separados por coma)
# ==============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
